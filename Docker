# Dockerfile — Employee Performance Predictor
# Build:  docker build -t epp .
# Run:    docker run -p 8501:8501 epp              (Streamlit)
#         docker run -p 8000:8000 epp uvicorn src.api:app --host 0.0.0.0 --port 8000

FROM python:3.11-slim

WORKDIR /app

# Install dependencies first (layer caching)
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy source
COPY . .

# Generate data + train model at build time
RUN python main.py

EXPOSE 8501 8000

# Default: launch Streamlit dashboard
CMD ["streamlit", "run", "app.py", \
     "--server.port=8501", \
     "--server.address=0.0.0.0", \
     "--server.headless=true"]
